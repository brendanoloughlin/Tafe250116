<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Style TargetType="TextBlock">
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="HorizontalAlignment" Value="Center" />
		<Setter Property="FontSize" Value="72px" />
		<Setter Property="FontWeight" Value="Bold" />
		<Setter Property="Foreground" Value="#003049" />
		<Setter Property="FontFamily" Value="Cambria" />
	</Style>
	
	<Style x:Key="ButtonStyle" TargetType="Button">
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="HorizontalAlignment" Value="Center" />
		<Setter Property="Background" Value="#669bbc" />
		<Setter Property="BorderThickness" Value="3" />
		<Setter Property="BorderBrush" Value="#003049" />
		<Setter Property="Height" Value="140px" />
		<Setter Property="Width" Value="360px" />
		<Setter Property="FontSize" Value="30px" />
	</Style>

</ResourceDictionary>

	