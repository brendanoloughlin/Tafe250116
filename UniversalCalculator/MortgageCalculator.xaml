<Page x:Class="Calculator.MortgageCalculator" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:control="using:Calculator.Controls" Background="{ThemeResource SystemControlAcrylicWindowBrush}">
	<!-- resources -->
	<Page.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="/Resources/MortgageCalculatorResources.xaml" />
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Page.Resources>

    <Grid Style="{StaticResource GridStyle}">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock x:Name="mortgageTitle" Style="{StaticResource TitleText}" Text="Mortgage Calculator" Grid.Row="0" Grid.ColumnSpan="2"/>

		<TextBlock x:Name="principalBorrow" Style="{StaticResource SmallText}" Text="Principal Borrow $:" Grid.Column="0" Grid.Row="1" />
		<TextBox x:Name="principalBorrowBox"  Style="{StaticResource Textbox}" Grid.Column="1" Grid.Row="1" />

		<TextBlock x:Name="years" Style="{StaticResource SmallText}" Text="Years:" Grid.Column="0" Grid.Row="2" />
		<TextBox x:Name="yearsBox" Style="{StaticResource Textbox}" Grid.Column="1" Grid.Row="2" />

		<TextBlock x:Name="months" Style="{StaticResource SmallText}" Text="Months:" Grid.Column="0" Grid.Row="3" />
		<TextBox x:Name="monthsBox" Style="{StaticResource Textbox}" Grid.Column="1" Grid.Row="3" />

		<TextBlock x:Name="yearlyRate" Style="{StaticResource SmallText}" Text="Yearly Interest Rate:" Grid.Column="0" Grid.Row="4" />
		<TextBox x:Name="yearlyRateBox" Style="{StaticResource Textbox}" Grid.Column="1" Grid.Row="4" />

		<TextBlock x:Name="monthlyRate" Style="{StaticResource SmallText}" Text="Monthly Interest Rate:" Grid.Column="0" Grid.Row="5" />
		<TextBox x:Name="monthlyRateBox" Style="{StaticResource Textbox}" Grid.Column="1" Grid.Row="5" IsReadOnly="True" MaxLength="6" />

		<TextBlock x:Name="monthlyRepayment" Style="{StaticResource SmallText}" Text="Monthly Repayment:" Grid.Column="0" Grid.Row="6" />
		<TextBox x:Name="monthlyRepaymentBox" Style="{StaticResource Textbox}" Grid.Column="1" Grid.Row="6" IsReadOnly="True" />

		<Button x:Name="calculateBTN" Style="{StaticResource Button}" Content="Calculate" Grid.Row="7" Grid.ColumnSpan="2" Click="Calculate"/>
		<Button x:Name="exitBTN" Style="{StaticResource Button}" Content="Exit" Grid.Row="8"  Grid.ColumnSpan="2" Click="Exit"/>
	</Grid>
</Page>
